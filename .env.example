# Copy to .env and fill in.

# REQUIRED.
# TMDB v3 API Key. Get one free at https://www.themoviedb.org/settings/api (use the v3 "API Key" string,
# not the v4 read-access JWT).
TMDB_API_KEY=

# OPTIONAL — used by 0.1.1.3 multi-source corroboration. Leave blank to skip OMDb in Pass B.
# Free tier: 1000 requests/day. Sign up at http://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# OPTIONAL — used by 0.1.1.3 multi-source corroboration. Leave blank to skip TVDB in Pass B.
# Free for personal use. Sign up at https://thetvdb.com/dashboard/account/apikeys
# Token is cached on disk under data/tvdb-token.json (30-day TTL).
TVDB_API_KEY=

# REQUIRED.
# MEDIA_ROOT: absolute path to the media folder.
# Windows dev example: D:\TestMedia
# Mac prod example:    /Volumes/media
MEDIA_ROOT=

# HTTP server port (used in 0.1.2; harmless to set now).
PORT=3000

# Database file path (defaults to data/media.db if unset).
DB_PATH=data/media.db

# 0.1.9 — Maximum concurrent player instances across the whole server.
# Hitting this returns 503 capacity_exceeded to new /open requests. Default 3.
MAX_CONCURRENT_PLAYERS=3

# 0.1.9 — Maximum concurrent players per identity (today: per client IP).
# When 1 (default), a new /open from an IP that already has a player is
# treated as a media-swap on the existing instance. When >1, additional
# /open requests create new instances up to the cap.
MAX_PLAYERS_PER_IP=1

# 0.1.9 — Encoder pacing. ffmpeg is suspended when its emitted segments
# cover this many seconds past the client's reported position. Default 30.
ENCODE_AHEAD_SECONDS=30

# 0.1.9 — Encoder pacing resume threshold. Hysteresis vs ENCODE_AHEAD_SECONDS
# prevents flapping. Default 10.
ENCODE_RESUME_SECONDS=10

# 0.1.9 — Idle GC for player instances. Wipe a player's segments + state
# if no /state ping arrives for this long. Default 1800 (30 min).
PLAYER_IDLE_TIMEOUT_SECONDS=1800
